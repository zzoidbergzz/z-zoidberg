# Security Knowledge — Environment Variables
# Copy to .env and fill in values

# Core
DATABASE_URL=postgresql+asyncpg://sk:sk@localhost/sk
REDIS_URL=redis://localhost:6379
SECRET_KEY=change-me-in-production

# Auth
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Admin
BOOTSTRAP_ADMIN_TENANT=z.je

# Enrichment Providers (BYOK)
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
IPINFO_TOKEN=
GREYNOISE_API_KEY=
ABUSEIPDB_API_KEY=
URLSCAN_API_KEY=
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com
NVD_API_KEY=

# Recorded Future (BYOK)
RecordedFutureAPI=

# OpenCTI
OPENCTI_URL=
OPENCTI_TOKEN=

# MISP
MISP_URL=
MISP_KEY=

# LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_BASE_URL=
LLM_API_KEY=

# Embeddings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Feed Poller
FEED_POLL_USER_AGENT=Zoidberg/1.0 (Security Knowledge Platform; https://z.je)
FEED_POLL_INTERVAL_SECONDS=1200

# Tor Scraping
TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9050
TOR_SCRAPE_INTERVAL_SECONDS=1200
TOR_SCRAPE_ENABLED=false

# AI Enrichment (post-scrape)
AI_ENRICHMENT_PROVIDER=
AI_ENRICHMENT_MODEL=gpt-4o-mini

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Slack (optional)
SLACK_WEBHOOK_URL=
